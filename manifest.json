{
  "manifest_version": 3,
  "name": "GitHub Authorized Apps — Inline Permissions",
  "short_name": "GitHub App Perms",
  "version": "1.0.0",
  "description": "Shows Authorized OAuth App and GitHub App permissions inline on the GitHub applications settings page.",
  "permissions": ["storage"],
  "host_permissions": ["https://github.com/*"],
  "icons": {
    "16": "assets/icon-16.png",
    "32": "assets/icon-32.png",
    "48": "assets/icon-48.png",
    "128": "assets/icon-128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "GitHub Authorized Apps Permissions",
    "default_icon": {
      "16": "assets/icon-16.png",
      "32": "assets/icon-32.png",
      "48": "assets/icon-48.png",
      "128": "assets/icon-128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://github.com/settings/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
